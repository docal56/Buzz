# Convex
# Set after running `pnpm dlx convex dev` (it writes these to .env.local automatically)
NEXT_PUBLIC_CONVEX_URL=

# Convex deploy key (used by Vercel build only, not needed for local dev)
# Get from Convex dashboard → Settings → Deploy Keys
CONVEX_DEPLOY_KEY=

# Clerk
# Get from clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk JWT issuer (also set this in the Convex dashboard env vars)
# Get from clerk.com → JWT Templates → Convex template → Issuer URL
CLERK_JWT_ISSUER_DOMAIN=
